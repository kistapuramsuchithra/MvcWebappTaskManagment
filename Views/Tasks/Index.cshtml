@model IEnumerable<MVCTaskManagmentApp.Models.TaskItem>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Task List</h2>
    <a asp-action="Create" class="btn btn-primary">Add New Task</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Due Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.DueDate.ToShortDateString()</td>
                    <td>
                        <span class="badge @(item.IsCompleted ? "bg-success" : "bg-warning")">
                        @(item.IsCompleted ? "Completed" : "Pending")
                        </span>
                    </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                        Edit
                    </a>

                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">
                        Details
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                        Delete
                    </a>
                </td>
                </tr>
        }
    </tbody>
</table>