@model MVCTaskManagmentApp.Models.TaskItem

<h2>Task Details</h2>

<hr />

<dl class="row">

    <dt class="col-sm-3">
        Title
    </dt>

    <dd class="col-sm-9">
        @Model.Title
    </dd>

    <dt class="col-sm-3">
        Due Date
    </dt>

    <dd class="col-sm-9">
        @Model.DueDate.ToShortDateString()
    </dd>

    <dt class="col-sm-3">
        Status
    </dt>

    <dd class="col-sm-9">
        @(Model.IsCompleted ? "Completed" : "Pending")
    </dd>

</dl>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
    Edit
</a>

<a asp-action="Index" class="btn btn-secondary">
    Back
</a>